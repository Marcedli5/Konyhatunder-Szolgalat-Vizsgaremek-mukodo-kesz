<UserControl x:Class="WPF_AdminFelulet.Views.RendelesekAddUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WPF_AdminFelulet.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1400"
             d:DataContext="{d:DesignInstance Type=vm:RendelesekAddViewModel}">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ShellBrush" Color="#FFF3F6FB" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#FFD9E3F0" />
        <SolidColorBrush x:Key="InkBrush" Color="#FF243142" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF677689" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF4E6FAE" />
        <SolidColorBrush x:Key="SoftAccentBrush" Color="#FFEAF0F7" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF547D63" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,12,0,4" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="EditorComboStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="MinWidth" Value="220" />
        </Style>

        <Style x:Key="DatePickerStyle" TargetType="DatePicker">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="2" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SoftAccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        </Style>

        <Style x:Key="ListBoxItemCardStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="OuterBorder"
                                Background="Transparent"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="#0E4E6FAE" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="#184E6FAE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,16"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding Description}"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        VerticalAlignment="Top"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Új rendelés rögzítése"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Az innen felvitt rendelések az aktuális session listájába kerülnek a jobb oldalon."
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap" />

                        <CheckBox Content="Meglévő felhasználóhoz rögzítem a rendelést"
                                  IsChecked="{Binding IsExistingCustomer}"
                                  Margin="0,16,0,0"
                                  FontWeight="SemiBold"
                                  Foreground="{StaticResource InkBrush}" />

                        <Border Margin="0,12,0,0"
                                Padding="12"
                                Background="#FFF8FBFF"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExistingCustomer}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Meglévő megrendelő *"
                                           Margin="0,0,0,4"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding Customers}"
                                          SelectedItem="{Binding SelectedCustomer}"
                                          DisplayMemberPath="DisplayText"
                                          Style="{StaticResource EditorComboStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Padding="12"
                                Background="#FFFBFDFF"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNewCustomer}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Új megrendelő adatai"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InkBrush}" />

                                <TextBlock Text="Teljes név *" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding NewCustomerName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource EditorTextBoxStyle}" />

                                <TextBlock Text="Email *" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding NewCustomerEmail, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource EditorTextBoxStyle}" />

                                <TextBlock Text="Telefonszám" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding NewCustomerPhone, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource EditorTextBoxStyle}" />

                                <TextBlock Text="Lakcím *" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding NewCustomerAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource EditorTextBoxStyle}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="72" />

                                <TextBlock Text="{Binding NewCustomerPreviewText}"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Menü *" Style="{StaticResource LabelStyle}" />
                        <ComboBox ItemsSource="{Binding Menus}"
                                  SelectedItem="{Binding SelectedMenu}"
                                  DisplayMemberPath="DisplayText"
                                  Style="{StaticResource EditorComboStyle}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Mennyiség *"
                                           Margin="0,0,0,4"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="SemiBold" />
                                <TextBox Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}"
                                         PreviewTextInput="NumberOnlyTextBox_PreviewTextInput"
                                         DataObject.Pasting="NumberOnlyTextBox_Pasting"
                                         Style="{StaticResource EditorTextBoxStyle}" 
                                         />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Kiszállítási dátum *"
                                           Margin="0,0,0,4"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontWeight="SemiBold" />
                                <DatePicker SelectedDate="{Binding SelectedDeliveryDate}"
                                            Style="{StaticResource DatePickerStyle}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding QuantityHintText}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding SelectedDeliveryDayText}"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold" />

                        <TextBlock Text="Megjegyzés" Style="{StaticResource LabelStyle}" />
                        <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource EditorTextBoxStyle}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="110" />

                        <Border Margin="0,16,0,0"
                                Padding="12"
                                Background="#FFF8FBFF"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="Gyors összegzés"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="{Binding OrderPreviewText}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,14,0,0"
                                Padding="12"
                                Background="#FFF6FAF7"
                                BorderBrush="#FFD9E7DE"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="Kötelező mezők: menü, mennyiség, dátum, valamint megrendelő vagy új felhasználó adatai."
                                           Foreground="{StaticResource InkBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="A jobb oldali lista csak az ebben a megnyitásban felvitt tételeket mutatja."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="Rendelés rögzítése"
                                    Command="{Binding AddOrderCommand}"
                                    Style="{StaticResource ActionButtonStyle}" />
                            <Button Grid.Column="2"
                                    Content="Session lista törlése"
                                    Command="{Binding ClearSessionCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1"
                      Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,16"
                            Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Aktuális session rendelései"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Itt csak az ezen a lapon most felvitt rendelések jelennek meg, nem a teljes adatbázis."
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SessionSummaryText}"
                                       Margin="0,14,0,0"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource CardStyle}">
                        <ListBox ItemsSource="{Binding SessionOrders}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemContainerStyle="{StaticResource ListBoxItemCardStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16"
                                            Background="#FFFBFDFF"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding CustomerName}"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource InkBrush}" />
                                                    <TextBlock Text="{Binding Address}"
                                                               Margin="0,4,0,0"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        Content="Eltávolít"
                                                        Command="{Binding DataContext.RemoveSessionOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="12,6"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </Grid>

                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Margin="0,0,8,0"
                                                        Padding="10,8"
                                                        Background="#FFF8FBFF"
                                                        BorderBrush="{StaticResource LineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Text="Menü"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding MenuName}"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="{StaticResource InkBrush}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1"
                                                        Margin="4,0"
                                                        Padding="10,8"
                                                        Background="#FFF8FBFF"
                                                        BorderBrush="{StaticResource LineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Text="Mennyiség"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding QuantityText}"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="{StaticResource InkBrush}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="2"
                                                        Margin="8,0,0,0"
                                                        Padding="10,8"
                                                        Background="#FFF8FBFF"
                                                        BorderBrush="{StaticResource LineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Text="Dátum"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding DeliveryDateText}"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="{StaticResource InkBrush}" />
                                                        <TextBlock Text="{Binding DeliveryDayName}"
                                                                   Margin="0,2,0,0"
                                                                   Foreground="{StaticResource AccentBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <TextBlock Text="Megjegyzés"
                                                       Style="{StaticResource LabelStyle}" />
                                            <TextBlock Text="{Binding CommentText}"
                                                       Foreground="{StaticResource InkBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
