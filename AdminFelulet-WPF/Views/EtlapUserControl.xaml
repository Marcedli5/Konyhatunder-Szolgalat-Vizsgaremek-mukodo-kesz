<UserControl x:Class="WPF_AdminFelulet.Views.EtlapUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WPF_AdminFelulet.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:EtlapViewModel}">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ShellBrush" Color="#FFF3F6FB" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#FFD9E3F0" />
        <SolidColorBrush x:Key="InkBrush" Color="#FF243142" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF677689" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF4E6FAE" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FFEAF0F7" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        </Style>

        <Style x:Key="EditorComboStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="IsEditable" Value="True" />
            <Setter Property="IsTextSearchEnabled" Value="True" />
            <Setter Property="StaysOpenOnEdit" Value="True" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ShellBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="16,16,16,0"
                Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Heti étlap"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="Heti étlap szerkesztése Backend adatokkal."
                               Margin="0,4,0,0"
                               Foreground="{StaticResource MutedBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="18,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Hét kiválasztása"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedBrush}" />
                    <ComboBox Width="250"
                              ItemsSource="{Binding AvailableWeeks}"
                              SelectedItem="{Binding SelectedWeek}"
                              DisplayMemberPath="Label"
                              Style="{StaticResource EditorComboStyle}" />
                    <TextBlock Text="{Binding SelectedWeekCaption}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Frissítés"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="{Binding SaveButtonText}"
                                Command="{Binding SaveCommand}"
                                Margin="8,0,0,0"
                                Style="{StaticResource ActionButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Padding="16,12,16,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding MenuDays}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DayName}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource InkBrush}" />
                                        <TextBlock Text="  " />
                                        <TextBlock Text="{Binding FormattedDate}"
                                                   VerticalAlignment="Bottom"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>

                                    <CheckBox Grid.Column="1"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding HasPlus}"
                                              Visibility="{Binding CanTogglePlus, Converter={StaticResource BoolToVisibilityConverter}}"
                                              Content="Plusz aznap elérhető"
                                              FontWeight="SemiBold"
                                              Foreground="{StaticResource InkBrush}" />
                                </Grid>

                                <ItemsControl Margin="0,12,0,0"
                                              ItemsSource="{Binding MenuVariants}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="300"
                                                    Margin="0,0,10,10"
                                                    Padding="12"
                                                    Background="#FFFBFDFF"
                                                    BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <StackPanel>
                                                    <Border Height="4"
                                                            Background="{Binding AccentBrush}"
                                                            CornerRadius="6" />
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Margin="0,10,0,0"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource InkBrush}" />

                                                    <StackPanel Visibility="{Binding IsPlusOnly, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="Desszert"
                                                                   Margin="0,10,0,0"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource MutedBrush}" />
                                                        <ComboBox ItemsSource="{Binding DataContext.PlusOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding SelectedPlus}"
                                                                  DisplayMemberPath="Name"
                                                                  Style="{StaticResource EditorComboStyle}" />
                                                    </StackPanel>

                                                    <StackPanel>
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlusOnly}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>

                                                        <TextBlock Text="Leves vagy előétel"
                                                                   Margin="0,10,0,0"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource MutedBrush}" />
                                                        <ComboBox ItemsSource="{Binding DataContext.StarterOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding SelectedStarter}"
                                                                  DisplayMemberPath="Name"
                                                                  Style="{StaticResource EditorComboStyle}" />

                                                        <TextBlock Text="Főétel"
                                                                   Margin="0,10,0,0"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource MutedBrush}" />
                                                        <ComboBox ItemsSource="{Binding DataContext.MainCourseOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding SelectedMainCourse}"
                                                                  DisplayMemberPath="Name"
                                                                  Style="{StaticResource EditorComboStyle}" />

                                                        <ComboBox ItemsSource="{Binding DataContext.SideDishOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  Margin="0,10,0,0"
                                                                  SelectedItem="{Binding SelectedSideDish}"
                                                                  DisplayMemberPath="Name"
                                                                  Style="{StaticResource EditorComboStyle}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
