@page
@model Frontend_ASP.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Regisztráció";
}

<section class="page-hero page-hero-soft">
    <div class="container auth-shell">
        <article class="auth-card">
            <span class="eyebrow">Új fiók</span>
            <h1>Regisztráció</h1>
            <p class="auth-lead">Hozz létre egy saját fiókot néhány adat megadásával.</p>

            @if (!string.IsNullOrWhiteSpace(Model.FormMessage))
            {
                <div class="identity-message identity-message-error">@Model.FormMessage</div>
            }

            <form method="post" class="auth-form">
                <input asp-for="Input.ReturnUrl" type="hidden" />

                <div class="auth-field">
                    <label asp-for="Input.Username"></label>
                    <input asp-for="Input.Username" class="identity-input" autocomplete="nickname" />
                    <span asp-validation-for="Input.Username" class="text-danger"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" class="identity-input" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.PhoneNumber"></label>
                    <input asp-for="Input.PhoneNumber" class="identity-input" autocomplete="tel" />
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Address"></label>
                    <input asp-for="Input.Address" class="identity-input" autocomplete="street-address" />
                    <span asp-validation-for="Input.Address" class="text-danger"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Password"></label>
                    <input asp-for="Input.Password" class="identity-input" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.ConfirmPassword"></label>
                    <input asp-for="Input.ConfirmPassword" class="identity-input" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="auth-actions">
                    <button type="submit" class="btn btn-brand-primary auth-submit">Regisztráció</button>
                    <a class="btn btn-brand-secondary" asp-page="./Login" asp-route-email="@Model.Input.Email">Vissza a bejelentkezéshez</a>
                </div>
            </form>
        </article>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
