@page "/kapcsolat"
@{
    ViewData["Title"] = "Kapcsolat";
}

<section class="page-hero page-hero-soft">
    <div class="container page-hero-grid">
        <div>
            <span class="eyebrow">Kapcsolat</span>
            <h1>Elérhetőek vagyunk, ha bármi kérdésed merül fel a rendelés során.</h1>
            <p>Ha kérdésed van, vagy segítségre van szükséged, vedd fel velünk a kapcsolatot bizalommal! Ügyfélszolgálatunk készséggel áll rendelkezésedre telefonon vagy e-mailben. Célunk, hogy minden megkeresésre gyorsan és hatékonyan válaszoljunk, hogy a rendelési élményed mindig zökkenőmentes legyen.</p>
        </div>
        <div class="contact-logo-card">
            <img src="~/images/Etterem_logo_fekete.png" alt="Konyhatündér Szolgálat logó" class="contact-logo" />
        </div>
    </div>
</section>

<section class="content-section">
    <div class="container contact-grid">
        <article class="content-card">
            <h2>Elérhetőségek</h2>
            <p><strong>Telefon:</strong> +36 30 123 4567</p>
            <p><strong>E-mail:</strong> rendeles@konyhatunder.hu</p>
            <p><strong>Cím:</strong> 9400 Sopron, Őszapó utca 12.</p>
        </article>
        <article class="content-card">
            <h2>Kiszállítás:</h2>
            <p>Hétfő - péntek: 08:00 - 18:00</p>
            <p>Szombat: 09:00 - 14:00</p>
            <p>Vasárnap: Nincs</p>
        </article>
    </div>
</section>
