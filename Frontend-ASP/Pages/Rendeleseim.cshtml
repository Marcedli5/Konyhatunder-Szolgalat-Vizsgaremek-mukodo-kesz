@page "/rendeleseim"
@model Frontend_ASP.Pages.RendeleseimModel
@{
    ViewData["Title"] = "Rendeléseim";
}

<section class="page-hero">
    <div class="container">
        <span class="eyebrow">Rendeléseim</span>
        <h1>Itt látod a leadott rendeléseidet.</h1>
    </div>
</section>

<section class="content-section">
    <div class="container editor-layout">
        @if (!Model.Orders.Any())
        {
            <div class="content-card">
                <h2>Még nincs leadott rendelésed.</h2>
                <p>Az étlapról kosárba helyezett menüket a kosár oldalon tudod véglegesíteni.</p>
            </div>
        }
        else
        {
            @foreach (var order in Model.Orders)
            {
                <article class="editor-item">
                    <h3>Rendelés #@order.OrderId</h3>
                    <p class="editor-item-meta">@order.DeliveryDate.ToString("yyyy. MM. dd.") | Státusz: <strong>@order.Status</strong> | Összesen: <strong>@order.TotalPriceFt.ToString("N0") Ft</strong></p>
                    @if (!string.IsNullOrWhiteSpace(order.Comment))
                    {
                        <p>@order.Comment</p>
                    }
                    <ul class="menu-list">
                        @foreach (var item in order.Items)
                        {
                            <li>
                                <span>@($"{item.MenuCode} menü x {item.Quantity}")</span>
                                <span>@item.TotalPriceFt.ToString("N0") Ft</span>
                            </li>
                        }
                    </ul>
                </article>
            }
        }
    </div>
</section>
